# Dependency folders
node_modules/
builder/node_modules/

# Compiled output — generated by build steps, never commit
dist/
builder/dist/

# Generated render output — recreated at runtime
image.bin
image.png

# Local secrets/config
.env
.env.local
.env.*.local
secrets.yaml

# Cryptographic keys / certs — never commit
*.pem
*.key
*.p12
*.pfx
*.keystore
*.crt
*.cer

# Test / build / editor cruft
coverage/
*.log
*.tsbuildinfo
.idea/
*.swp
*.swo
*~

# System files
.DS_Store
thumbs.db

# VS Code specific
.vscode/

# Backup files
*.bak

# Local-only working notes and scratch files — not part of the project
ignore/
update.md