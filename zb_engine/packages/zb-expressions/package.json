{
  "name": "@zb/expressions",
  "version": "0.1.3-dev.20260709",
  "private": true,
  "description": "Shared expression engine (bindings, math, logic, pipe-syntax) used by both the ZerryBit Engine server and the builder SPA.",
  "license": "MIT",
  "author": "ZerryBit",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZerryGit/zb-ha-app.git",
    "directory": "zb_engine/packages/zb-expressions"
  },
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm && npm run build:esm-pkg",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:esm-pkg": "node -e \"require('fs').writeFileSync('dist/esm/package.json','{\\\"type\\\":\\\"module\\\"}\\n')\"",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
